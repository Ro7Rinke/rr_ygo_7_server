generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nickname  String   @unique
  status    Int      @default(1)
  is_admin  Int      @default(0)
  
  rp        Int      @default(0)
  cash      Int      @default(0)
  tickets   Int      @default(0)
  gold_tickets   Int  @default(0)     
  wins      Int      @default(0)
  loses     Int      @default(0)
  draws     Int      @default(0)
  
  created_at DateTime @default(now())

  user_cards UserCard[]
  games      Game[]
  gamePlayer GamePlayer[]
  replayHashes ReplayHash[]

  @@map("user")
}

model Cards {
  id             Int      @id
  created_at     DateTime @default(now())
  updated_at     DateTime?
  status         Int      @default(0)
  in_game        Int      @default(0)
  introduced_by  String?
  released_by    String?

  hash    String?

  datas CardDatas?
  texts CardTexts?

  booster_cards BoosterCard[]
  selaed_deck_cards SealedDeckCard[]
  user_cards UserCard[] 

  @@map("cards")
}

model CardDatas {
  id        Int  @id
  ot        BigInt?
  alias     BigInt?
  setcode   BigInt?
  type      BigInt?
  atk       Int?
  def       Int?
  level     BigInt?
  race      BigInt?
  attribute BigInt?
  category  BigInt?

  card Cards @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("card_datas")
}

model CardTexts {
  id    Int    @id
  name  String?
  desc  String?

  str1  String?
  str2  String?
  str3  String?
  str4  String?
  str5  String?
  str6  String?
  str7  String?
  str8  String?
  str9  String?
  str10 String?
  str11 String?
  str12 String?
  str13 String?
  str14 String?
  str15 String?
  str16 String?

  card Cards @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("card_texts")
}

model Rarity {
  id     Int    @id
  code   String @unique
  title  String
  original_name  String

  level  Int

  booster_cards BoosterCard[]
  sealed_deck_cards SealedDeckCard[]

  @@map("rarities")
}

model Booster {
  id             Int     @id @default(autoincrement())
  title          String
  description    String?
  code           String  @unique

  prefix         String
  money_type     String

  price          Int
  cards_per_pack Int
  status         Int      @default(0)
  sale_status    Int      @default(0)

  created_at     DateTime @default(now())
  updated_at    DateTime? @updatedAt

  cards BoosterCard[]
  slots BoosterSlot[]

  @@map("boosters")
}

model BoosterCard {
  id         Int @id @default(autoincrement())

  booster_id Int
  card_id    Int
  rarity_id  Int

  booster Booster @relation(fields: [booster_id], references: [id], onDelete: Cascade)
  card    Cards   @relation(fields: [card_id], references: [id], onDelete: Cascade)
  rarity  Rarity  @relation(fields: [rarity_id], references: [id])

  @@unique([booster_id, card_id])
  @@map("booster_cards")
}

model BoosterSlot {
  id          Int @id @default(autoincrement())

  booster_id  Int
  position    Int

  unit_value  Int?

  booster Booster @relation(fields: [booster_id], references: [id], onDelete: Cascade)

  groups BoosterSlotGroup[]

  @@unique([booster_id, position])
  @@map("booster_slots")
}

model BoosterSlotGroup {
  id Int @id @default(autoincrement())

  slot_id Int

  min_rarity_level Int
  max_rarity_level Int

  chance Float

  slot BoosterSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@map("booster_slot_groups")
}

model UserCard {
  id        Int @id @default(autoincrement())

  user_id   Int
  card_id   Int

  amount    Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card Cards @relation(fields: [card_id], references: [id], onDelete: Cascade)

  @@unique([user_id, card_id])
  @@map("user_cards")
}

model Game {
  id            Int      @id @default(autoincrement())

  user_id       Int

  duel_id       String?

  type          Int      @default(0)
  status        Int      @default(0)
  result_status Int      @default(0)

  has_replay    Int      @default(0)

  duel_date     DateTime?

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  players       GamePlayer[]

  @@unique([user_id, duel_id])
  @@index([user_id])

  @@map("game")
}

model GamePlayer {
  id       Int @id @default(autoincrement())

  game_id  Int
  user_id  Int

  game     Game @relation(fields: [game_id], references: [id], onDelete: Cascade)
  user     User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([game_id, user_id])
  @@index([game_id])

  @@map("game_player")
}

model ReplayHash {
  id         Int      @id @default(autoincrement())
  user_id    Int
  hash       String
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, hash])
  @@index([hash])
  @@map("replay_hash")
}

model SealedDeck {
  id             Int     @id @default(autoincrement())
  title          String
  description    String?
  code           String  @unique

  prefix         String
  money_type     String

  price          Int
  total_cards    Int
  status         Int      @default(0)
  sale_status    Int      @default(0)
  is_initial     Int      @default(0)

  created_at     DateTime @default(now())
  updated_at    DateTime? @updatedAt

  cards SealedDeckCard[]

  @@map("sealed_decks")
}

model SealedDeckCard {
  id         Int @id @default(autoincrement())

  sealed_deck_id Int
  card_id    Int
  rarity_id  Int
  amount     Int     @default(1)

  sealed_deck SealedDeck @relation(fields: [sealed_deck_id], references: [id], onDelete: Cascade)
  card    Cards   @relation(fields: [card_id], references: [id], onDelete: Cascade)
  rarity  Rarity  @relation(fields: [rarity_id], references: [id])

  @@map("sealed_deck_cards")
}