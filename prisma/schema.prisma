// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nickname  String   @unique
  status    Int      @default(1)
  is_admin  Int      @default(0)
  
  // Stats do Player
  rp        Int      @default(0)
  cash      Int      @default(0)
  wins      Int      @default(0)
  loses     Int      @default(0)
  draws     Int      @default(0)
  
  created_at DateTime @default(now())

  user_cards UserCard[]
}

model Cards {
  id             Int      @id
  created_at     DateTime @default(now())
  updated_at     DateTime?
  status         Int      @default(0)
  in_game        Int      @default(0)
  introduced_by  String?
  released_by    String?

  hash    String?

  datas CardDatas?
  texts CardTexts?

  booster_cards BoosterCard[]
  user_cards UserCard[] 

  @@map("cards")
}

model CardDatas {
  id        Int  @id
  ot        BigInt?
  alias     BigInt?
  setcode   BigInt?
  type      BigInt?
  atk       Int?
  def       Int?
  level     BigInt?
  race      BigInt?
  attribute BigInt?
  category  BigInt?

  card Cards @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("datas")
}

model CardTexts {
  id    Int    @id
  name  String?
  desc  String?

  str1  String?
  str2  String?
  str3  String?
  str4  String?
  str5  String?
  str6  String?
  str7  String?
  str8  String?
  str9  String?
  str10 String?
  str11 String?
  str12 String?
  str13 String?
  str14 String?
  str15 String?
  str16 String?

  card Cards @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("texts")
}

model Rarity {
  id     Int    @id
  code   String @unique
  title  String

  booster_cards BoosterCard[]

  slot_chances BoosterSlotRarityChance[]

  min_slots BoosterSlot[] @relation("min_rarity")
  max_slots BoosterSlot[] @relation("max_rarity")

  @@map("rarities")
}

model Booster {
  id            Int     @id @default(autoincrement())
  title         String
  description   String?
  code          String  @unique
  price         Int
  cards_per_pack Int
  status        Int      @default(0)

  created_at    DateTime @default(now())

  cards BoosterCard[]
  slots BoosterSlot[]

  @@map("boosters")
}

model BoosterCard {
  id         Int @id @default(autoincrement())

  booster_id Int
  card_id    Int
  rarity_id  Int

  booster Booster @relation(fields: [booster_id], references: [id], onDelete: Cascade)
  card    Cards   @relation(fields: [card_id], references: [id], onDelete: Cascade)
  rarity  Rarity  @relation(fields: [rarity_id], references: [id])

  @@unique([booster_id, card_id])
  @@map("booster_cards")
}

model BoosterSlot {
  id          Int @id @default(autoincrement())

  booster_id  Int
  position    Int

  min_rarity_id Int
  max_rarity_id Int

  unit_value  Int?

  booster Booster @relation(fields: [booster_id], references: [id], onDelete: Cascade)

  min_rarity Rarity @relation("min_rarity", fields: [min_rarity_id], references: [id])
  max_rarity Rarity @relation("max_rarity", fields: [max_rarity_id], references: [id])

  chances BoosterSlotRarityChance[]

  @@unique([booster_id, position])
  @@map("booster_slots")
}

model BoosterSlotRarityChance {
  id Int @id @default(autoincrement())

  slot_id   Int
  rarity_id Int

  chance    Float

  slot   BoosterSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  rarity Rarity      @relation(fields: [rarity_id], references: [id])

  @@unique([slot_id, rarity_id])
  @@map("booster_slot_rarity_chances")
}

model UserCard {
  id        Int @id @default(autoincrement())

  user_id   Int
  card_id   Int

  amount    Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card Cards @relation(fields: [card_id], references: [id], onDelete: Cascade)

  @@unique([user_id, card_id])
  @@map("user_cards")
}